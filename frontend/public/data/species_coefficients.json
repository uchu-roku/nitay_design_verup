{
  "_meta": {
    "description": "林分密度管理図係数テーブル - 推定材積・推定本数計算用",
    "formula": {
      "estimated_volume_density_m3ha": "V_est = (HA当蓄積N + HA当蓄積L) * correction_factor",
      "correction_factor": "衛星材積密度(245.5) / 森林簿材積密度(283.0) = 0.8675",
      "estimated_volume_m3": "V_total = V_est * 面積(ha)",
      "estimated_density_trees_ha": "N_est = b3 * H^b4 / (1/V_est - b1 * H^b2)  ※ V_est>0, H>0, 分母>0 のとき",
      "estimated_trees": "N_total = N_est * 面積(ha)"
    },
    "correction": {
      "satellite_volume_m3ha": 245.5,
      "forest_registry_volume_m3ha": 283.0,
      "correction_factor": 0.8675,
      "reference_komaban": "林班55-76（基準小班）",
      "note": "基準小班で得られた人工衛星分析結果を用いて森林簿材積を補正"
    },
    "sources": [
      "西園朋広・井上昭夫・細田和男(2013) 収量比数と相対幹距との関係. 森林計画誌47:16-28",
      "安藤貴(1968) 同齢単純林の密度管理. 林試報210",
      "林野庁(2024) 林分密度管理図による収穫予想表作成の手順書 民有林スギ人工林版"
    ],
    "equation_basis": "安藤(1968)の競争密度効果式: 1/v = A*N + B, A=b1*H^b2, B=b3*H^b4 より V=N*v なので 1/V = b1*H^b2 + b3*H^b4/N",
    "last_updated": "2026-04-27"
  },
